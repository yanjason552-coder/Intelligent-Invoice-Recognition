# Example environment file (DO NOT commit secrets)
#
# Copy this file to `.env` and fill in real values.

# Database (business)
POSTGRES_SERVER=127.0.0.1
POSTGRES_PORT=5432
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=app

# Database (system) - optional
SYS_DB_HOST=127.0.0.1
SYS_DB_PORT=5432
SYS_DB_NAME=sys
SYS_DB_USER=postgres
SYS_DB_PASSWORD=postgres

# Backend
ENVIRONMENT=local
PROJECT_NAME=Invoice System
SECRET_KEY=changeme
FIRST_SUPERUSER=admin@example.com
FIRST_SUPERUSER_PASSWORD=ChangeMe123!

# CORS
BACKEND_CORS_ORIGINS=["http://localhost:5173","http://127.0.0.1:5173"]

# Security
ACCESS_TOKEN_EXPIRE_MINUTES=60
