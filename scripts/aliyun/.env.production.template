# ============================================
# 生产环境配置文件模板
# ============================================
# 使用方法：
# 1. 复制此文件为 .env: cp scripts/aliyun/.env.production.template .env
# 2. 编辑 .env 文件，填写所有必需配置
# 3. 运行部署检查: bash scripts/aliyun/check-deployment.sh
# ============================================

# ============================================
# 项目基本配置
# ============================================
PROJECT_NAME=智能发票识别系统
ENVIRONMENT=production
DOMAIN=your-domain.com
STACK_NAME=invoice-app-production
FRONTEND_HOST=dashboard.your-domain.com

# ============================================
# Docker镜像配置（使用阿里云容器镜像服务）
# ============================================
# 格式: registry.cn-hangzhou.aliyuncs.com/namespace/repository
# 示例: registry.cn-hangzhou.aliyuncs.com/invoice/backend
DOCKER_IMAGE_BACKEND=your-registry.cn-hangzhou.aliyuncs.com/invoice/backend
DOCKER_IMAGE_FRONTEND=your-registry.cn-hangzhou.aliyuncs.com/invoice/frontend
TAG=latest

# ============================================
# 安全配置（必须修改！）
# ============================================
# 生成SECRET_KEY: python3 -c "import secrets; print(secrets.token_urlsafe(32))"
SECRET_KEY=changethis

# ============================================
# 管理员账户配置
# ============================================
FIRST_SUPERUSER=admin@example.com
FIRST_SUPERUSER_PASSWORD=changethis

# ============================================
# 数据库配置
# ============================================
# 选项1: 使用Docker Compose中的PostgreSQL（推荐用于单机部署）
# POSTGRES_SERVER=db
# POSTGRES_PORT=5432

# 选项2: 使用外部PostgreSQL数据库（推荐用于生产环境）
POSTGRES_SERVER=your-db-host
POSTGRES_PORT=5432
POSTGRES_USER=postgres
# 生成POSTGRES_PASSWORD: python3 -c "import secrets; print(secrets.token_urlsafe(32))"
POSTGRES_PASSWORD=changethis
POSTGRES_DB=invoice_db

# ============================================
# Redis配置
# ============================================
REDIS_PASSWORD=

# ============================================
# CORS配置
# ============================================
# 允许的前端域名，用逗号分隔
BACKEND_CORS_ORIGINS=["https://dashboard.your-domain.com","http://localhost:5173"]

# ============================================
# 邮件配置（可选，用于密码重置等功能）
# ============================================
SMTP_TLS=True
SMTP_PORT=587
SMTP_HOST=
SMTP_USER=
SMTP_PASSWORD=
EMAILS_FROM_EMAIL=noreply@your-domain.com

# ============================================
# Traefik配置
# ============================================
TRAEFIK_USERNAME=admin
TRAEFIK_PASSWORD=changethis
TRAEFIK_EMAIL=admin@your-domain.com

# ============================================
# Sentry配置（可选，用于错误监控）
# ============================================
SENTRY_DSN=

# ============================================
# 其他配置
# ============================================
ACCESS_TOKEN_EXPIRE_MINUTES=60
