# Backend env example (DO NOT put secrets in git)
#
# 推荐：统一在仓库根目录维护 `.env`，后端会自动读取 `../.env`。
# 如果你必须在 backend/ 目录单独放置 `.env`，请复制本文件为 `.env` 并填写实际值。

SECRET_KEY=changeme
PROJECT_NAME=My Invoice Project
FIRST_SUPERUSER=admin@example.com
FIRST_SUPERUSER_PASSWORD=ChangeMe123!

# Database Configuration (recommended)
POSTGRES_SERVER=127.0.0.1
POSTGRES_PORT=5432
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=app

# Or DATABASE_URL (psycopg3)
# DATABASE_URL=postgresql+psycopg://postgres:postgres@127.0.0.1:5432/app
# SYS_DATABASE_URL=postgresql+psycopg://postgres:postgres@127.0.0.1:5432/sys

# CORS
BACKEND_CORS_ORIGINS=["http://localhost:5173","http://127.0.0.1:5173"]
